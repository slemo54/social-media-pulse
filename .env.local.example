# ============ SUPABASE ============
# Go to https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ============ MEGAPHONE ============
# Dashboard: https://cms.megaphone.fm → Account Settings → API
MEGAPHONE_API_KEY=xxxxxxxx
MEGAPHONE_NETWORK_ID=xxxxxxxx
MEGAPHONE_PODCAST_ID=xxxxxxxx

# ============ YOUTUBE ============
# Google Cloud Console → APIs & Services → Credentials
YOUTUBE_API_KEY=AIzaSy...
YOUTUBE_CHANNEL_ID=UC...
# OAuth 2.0 Client (for YouTube Analytics API)
YOUTUBE_CLIENT_ID=xxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...
# Get via OAuth Playground: https://developers.google.com/oauthplayground
YOUTUBE_OAUTH_REFRESH_TOKEN=1//0...

# ============ GOOGLE ANALYTICS 4 ============
# GA4 Admin → Property ID (numeric)
GA4_PROPERTY_ID=123456789
# Service Account JSON (entire content on one line)
# Create at: Google Cloud Console → IAM & Admin → Service Accounts → Keys → JSON
GA4_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ============ SOUNDCLOUD ============
# Register app at: https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=xxxxxxxx
SOUNDCLOUD_CLIENT_SECRET=xxxxxxxx
# Obtain via OAuth flow or /api/auth/soundcloud
SOUNDCLOUD_ACCESS_TOKEN=xxxxxxxx

# ============ RSS ============
# Megaphone dashboard → Podcast → Settings → Distribution → RSS Feed URL
RSS_FEED_URL=https://feeds.megaphone.fm/xxxxx

# ============ APP ============
# Generate with: openssl rand -hex 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# http://localhost:3000 for dev, your Vercel domain for prod
NEXT_PUBLIC_APP_URL=http://localhost:3000
